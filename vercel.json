{
  "headers": [
    {
      "source": "/chog/pfp(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; connect-src *; img-src * data: blob:; default-src *;"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/mon",  "destination": "/mon/",  "permanent": false },
    { "source": "/chog", "destination": "/chog/", "permanent": false },
    { "source": "/emo",  "destination": "/emo/",  "permanent": false },
    { "source": "/bob",  "destination": "/bob/",  "permanent": false },
    { "source": "/game",              "destination": "/", "permanent": false },
    { "source": "/game/",             "destination": "/", "permanent": false },
    { "source": "/game/index.html",   "destination": "/", "permanent": false },
    { "source": "/game/user.html",    "destination": "/", "permanent": false }
  ],
  "crons": [
    { "path": "/api/cron-check-alerts", "schedule": "0 0 * * *" }
  ]
}
